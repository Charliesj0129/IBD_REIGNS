  "stat_rules": [
    {
      "comment": "高發炎 (免疫 > 70): 更多治療與併發症，較少社交",
      "conditions": [
        {"type": "stat", "stat": "IMMUNE", "op": "gt", "value": 70}
      ],
      "modifiers": [
        {"themes": ["treatment", "complication"], "mult": 1.5},
        {"themes": ["social", "work"], "mult": 0.7}
      ]
    },
    {
      "comment": "低免疫 (< 30): 感染風險 (併發症)",
      "conditions": [
        {"type": "stat", "stat": "IMMUNE", "op": "lt", "value": 30}
      ],
      "modifiers": [
        {"themes": ["complication"], "mult": 2.0},
        {"themes": ["recovery"], "mult": 1.2}
      ]
    },
    {
      "comment": "危急健康 (< 30): 需要急救",
      "conditions": [
        {"type": "stat", "stat": "HEALTH", "op": "lt", "value": 30}
      ],
      "modifiers": [
        {"themes": ["recovery", "treatment"], "mult": 1.4},
        {"themes": ["work"], "mult": 0.5}
      ]
    },
    {
      "comment": "低理智 (< 30): 需要支持",
      "conditions": [
        {"type": "stat", "stat": "SANITY", "op": "lt", "value": 30}
      ],
      "modifiers": [
        {"themes": ["support", "family"], "mult": 1.3},
        {"themes": ["work"], "mult": 0.6}
      ]
    }
  ],
  "tag_rules": [
    {
      "comment": "共病加成 (Comorbidity Cascade): 每個活躍 EIM 增加併發症權重",
      "check_tags_any": ["JOINT_PAIN", "SKIN_EIM", "EYE_EIM", "ANEMIA"],
      "target_theme": "complication",
      "base_mult": 1.0,
      "per_tag_bonus": 0.3
    }
  ]
}
